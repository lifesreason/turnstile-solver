# --- 服务监听 ---
TURNSTILE_HOST=0.0.0.0
TURNSTILE_PORT=5072
TURNSTILE_THREAD=1
TURNSTILE_BROWSER_INSTANCES=1
TURNSTILE_BROWSER_TYPE=camoufox
TURNSTILE_DEBUG=0

# 懒加载浏览器：首次解题再启动
TURNSTILE_LAZY=1

# 默认任务结束后立即关闭浏览器，降低常驻内存
TURNSTILE_KEEP_BROWSER_ALIVE=0

# Camoufox 低资源启动模式：禁图、禁 WebRTC、放宽 COOP 隔离
TURNSTILE_LOW_RESOURCE_MODE=1

# 默认持续阻断图片/字体/样式等重资源；兼容性问题可设 1
TURNSTILE_UNBLOCK_RENDERING=0

# 默认每个解题任务由独立 worker 进程执行，避免浏览器内存留在主服务进程
TURNSTILE_WORKER_MODE=process
TURNSTILE_WORKER_TIMEOUT=120

# 仅 TURNSTILE_KEEP_BROWSER_ALIVE=1 时用于空闲回收
TURNSTILE_IDLE_SEC=60

# Docker /dev/shm 大小；复杂页面或更高并发可设 1gb / 2gb
TURNSTILE_SHM_SIZE=512mb

# 容器启动时校验内置 Camoufox 资产的最小体积
CAMOUFOX_MIN_CACHE_MB=500

# 启用后从工作目录 proxies.txt 读代理（每行一条）
# TURNSTILE_PROXY=0

# 设置后 createTask / getTaskResult 必须传相同 clientKey
# API_KEY=change-me-to-a-secret
