# 复制为 .env 后由 docker compose 自动读取并注入 environment
# cp .env.example .env

# --- 镜像 / 端口（仅 compose 使用）---
# TURNSTILE_IMAGE=ghcr.nju.edu.cn/lifesreason/turnstile-solver:latest
# TURNSTILE_PUBLISH_PORT=5072

# --- 服务监听 ---
TURNSTILE_HOST=0.0.0.0
TURNSTILE_PORT=5072
TURNSTILE_THREAD=1
TURNSTILE_BROWSER_INSTANCES=1
TURNSTILE_BROWSER_TYPE=camoufox
TURNSTILE_DEBUG=0

# 懒加载浏览器：首次解题再启动
TURNSTILE_LAZY=1

# 连续调用模式：首次任务启动浏览器，后续复用；空闲一段时间后释放
TURNSTILE_KEEP_BROWSER_ALIVE=1

# Camoufox 实验性低资源启动模式；默认关闭（开启容易影响 Turnstile 成功率）
TURNSTILE_LOW_RESOURCE_MODE=0

# Camoufox 资源档位：compact 限制 Firefox 子进程并关闭 cache/prefetch
# 兼容性问题可设 balanced / off
TURNSTILE_CAMOUFOX_PROFILE=compact

# 默认持续阻断非 CF 的图片/字体/样式等；兼容性问题可设 1
TURNSTILE_UNBLOCK_RENDERING=0

# 连续调用默认 inline 复用浏览器；需要每任务强隔离时可设 process
TURNSTILE_WORKER_MODE=inline
TURNSTILE_WORKER_TIMEOUT=120

# 单个 Turnstile 求解阶段最多等待多久
TURNSTILE_SOLVE_TIMEOUT_SEC=60

# 常驻浏览器最多复用多少个任务后强制回收；0 表示不按任务数回收
TURNSTILE_BROWSER_RECYCLE_TASKS=25

# 浏览器子进程 RSS 超过该阈值(MB)时任务结束后强制回收；0 关闭
TURNSTILE_BROWSER_RECYCLE_RSS_MB=800

# 从浏览器池取槽位的超时秒数；超时后标记失败并强制重建池
TURNSTILE_POOL_ACQUIRE_TIMEOUT_SEC=30

# 仅 TURNSTILE_KEEP_BROWSER_ALIVE=1 时用于空闲回收（秒）
TURNSTILE_IDLE_SEC=60

# Docker /dev/shm 大小；复杂页面或更高并发可设 1gb / 2gb
TURNSTILE_SHM_SIZE=512mb

# 容器启动时校验内置 Camoufox 资产的最小体积
CAMOUFOX_MIN_CACHE_MB=500

# 启用后从工作目录 proxies.txt 读代理（每行一条）
# TURNSTILE_PROXY=0

# 设置后 createTask / getTaskResult 必须传相同 clientKey
# API_KEY=change-me-to-a-secret
